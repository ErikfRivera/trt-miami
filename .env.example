# Canonical absolute URL used by metadataBase, sitemap, and OG links.
# Required in production once a custom domain is attached.
NEXT_PUBLIC_SITE_URL=https://trt-miami.vercel.app

# GA4 measurement ID (G-XXXXXXXXXX). Leave unset or set to G-PLACEHOLDER to
# disable GA4 wiring; the GoogleAnalytics script is then not rendered, so
# production stays analytics-clean until the real ID is supplied.
NEXT_PUBLIC_GA4_ID=G-PLACEHOLDER

# Google Search Console verification token (content of the meta tag). Leave
# unset or set to PLACEHOLDER to skip emitting the verification meta tag.
GSC_VERIFICATION_TOKEN=PLACEHOLDER

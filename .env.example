# Public site origin used by canonical / OG / sitemap / robots.
# In Vercel production this falls back to VERCEL_PROJECT_PRODUCTION_URL automatically.
NEXT_PUBLIC_SITE_URL=https://trt-miami.vercel.app

# Google Analytics 4 measurement ID (format: G-XXXXXXXXXX).
# When unset, the GA4 script is not emitted — useful for previews/dev.
NEXT_PUBLIC_GA4_ID=

# Google Search Console verification token (the `content` value of the
# `google-site-verification` meta tag from GSC's HTML tag method).
# When unset, no verification meta tag is rendered.
NEXT_PUBLIC_GSC_VERIFICATION=

# Lead capture form (STR-12) — delivery via Resend.
# When RESEND_API_KEY or LEAD_NOTIFICATION_EMAIL is missing the form still
# accepts submissions but returns a "mail relay not yet configured" message
# and logs a non-PII record on the server. Set both in production.
RESEND_API_KEY=
LEAD_NOTIFICATION_EMAIL=
# Optional: override From / Reply-To. `From` must be on a verified Resend
# domain in production; reply-to defaults to the submitter's email.
LEAD_NOTIFICATION_FROM=
LEAD_NOTIFICATION_REPLY_TO=
# Optional salt for the IP hash stored in the lead email (no raw IPs in logs).
LEAD_IP_HASH_SALT=

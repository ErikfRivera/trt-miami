# Canonical absolute URL used by metadataBase, sitemap, and OG links.
# Required in production once a custom domain is attached.
NEXT_PUBLIC_SITE_URL=https://trt-miami.vercel.app

# GA4 measurement ID (G-XXXXXXXXXX). Leave unset to disable GA4 wiring.
# Production-only — do not set in preview to avoid polluting analytics.
NEXT_PUBLIC_GA4_ID=

# Google Search Console verification token (the content of the meta tag).
# Set in production once GSC verification is run via the meta-tag method.
GOOGLE_SITE_VERIFICATION=

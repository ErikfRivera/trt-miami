# Public site origin used by canonical / OG / sitemap / robots.
# In Vercel production this falls back to VERCEL_PROJECT_PRODUCTION_URL automatically.
NEXT_PUBLIC_SITE_URL=https://trt-miami.vercel.app

# Google Analytics 4 measurement ID (format: G-XXXXXXXXXX).
# When unset, the GA4 script is not emitted — useful for previews/dev.
NEXT_PUBLIC_GA4_ID=

# Google Search Console verification token (the `content` value of the
# `google-site-verification` meta tag from GSC's HTML tag method).
# When unset, no verification meta tag is rendered.
NEXT_PUBLIC_GSC_VERIFICATION=

# Lead capture form (STR-12 / STR-207) — DB-only storage in v1.
# Postgres connection string (Neon serverless via Vercel marketplace integration).
# Auto-provisioned in Vercel — set locally with `vercel env pull .env.local`.
DATABASE_URL=

# GA4 Measurement Protocol API secret (Admin → Data Streams → Measurement Protocol).
# When unset, server-side `lead_submit` event is a no-op (still logged). The
# client-side `lead_submit` event continues to fire from the form regardless.
GA4_API_SECRET=

# Optional salt for the IP hash stored on the lead row (no raw IPs in logs).
LEAD_IP_HASH_SALT=
